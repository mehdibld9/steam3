# Supabase → Project Settings → Database → Connection string (URI)
# Use the "Session pooler" or "Direct connection" string (not Transaction pooler).
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres

# Required
PORT=8080

# Required in production
SESSION_SECRET=change-me-to-a-long-random-string

# Frontend build (dev only)
BASE_PATH=/

# Optional — force SSL for non-Supabase hosts
# DATABASE_SSL=true

# Optional
NODE_ENV=development
LOG_LEVEL=info
