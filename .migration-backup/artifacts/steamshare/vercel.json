{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && npx --yes pnpm@11.5.2 install",
  "buildCommand": "cd ../.. && PORT=3000 BASE_PATH=/ npx --yes pnpm@11.5.2 --filter @workspace/steamshare run build",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
