{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npx --yes pnpm@11.5.2 install --filter @workspace/steamshare...",
  "buildCommand": "PORT=3000 BASE_PATH=/ npx --yes pnpm@11.5.2 --filter @workspace/steamshare run build",
  "outputDirectory": "artifacts/steamshare/dist/public",
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
