{
  "version": 2,
  "framework": null,
  "buildCommand": "sh scripts/vercel-build.sh",
  "outputDirectory": "dist",
  "functions": {
    "artifacts/api-server/api/index.ts": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/artifacts/api-server/api/index.ts"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
